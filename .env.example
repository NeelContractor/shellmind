DATABASE_URL="postgresql://shellmind:shellmind@localhost:5432/shellmind"

# LLM Provider: "gemini" | "anthropic" | "openai" | "openrouter"
PROVIDER="openrouter"

# Model name (provider-specific)
# Gemini:     gemini-2.0-flash, gemini-1.5-pro
# Anthropic:  claude-sonnet-4-20250514, claude-opus-4-20250514
# OpenAI:     gpt-4o, gpt-4-turbo
# OpenRouter: anthropic/claude-3.5-sonnet, google/gemini-pro, google/gemma-4-26b-a4b-it:free, openai/gpt-oss-120b:free etc.
MODEL="openai/gpt-oss-20b:free"

# API Key for your chosen provider
API_KEY=""

# Optional: Web search via Brave Search API
BRAVE_API_KEY=""

# Optional: session name to auto-resume on start
DEFAULT_SESSION=""
