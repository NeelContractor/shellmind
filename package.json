{
  "name": "shellmind",
  "version": "1.0.0",
  "description": "A minimal terminal coding agent with multi-provider LLM support",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "bun --bun run prisma generate",
    "db:migrate": "bun --bun run prisma migrate dev",
    "db:push": "bun --bun run prisma db push",
    "db:studio": "bun --bun run prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^0.14.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.0",
    "openai": "^4.77.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}