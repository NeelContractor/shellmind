{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@prisma/generated": ["./generated/prisma/client"]
    },
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "src/**/*",
    "prisma.config.ts"
  ]
}
